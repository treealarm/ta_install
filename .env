GRPC_VMS_PORT=50051
CFG_VMS_PORT=5135
FS_VMS_PORT=5137
LOGGER_VMS_PORT=5138
ONVIF_SRV_PORT=5136
ONVIF_ACTORS_PORT=5141
UTILS_VMS_PORT=5139
ANALYTICS_VMS_PORT=5140
DAPR_GRPC_PORT=50001
WEB_VMS_PORT=5134
DAPR_CFG_APP_ID="vmscfg"
DAPR_ONVIF_APP_ID="vmsonvif"
DAPR_LOGGER_APP_ID="vmslogger"
DAPR_UTILS_APP_ID="vmsutils"
DAPR_ANALYTICS_APP_ID="vmsanalytics"
MEDIA_SERVER_PAIRS=vms:vmsfs
DAPR_STATE_STORE_NAME=statestore
PUBSUB_NAME="orderpubsub"

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_CFG_DB=ta_cfg
POSTGRES_FS_DB=ta_fs
POSTGRES_ANALYTICS_DB=ta_analytics

ANALYTICS_DEBOUNCE_SECONDS=10
ANALYTICS_RETAIN_TIMEOUT_SECONDS=30
# The bundled video_a worker (analytics-worker service in docker-compose.yml). Comma-separated
# list; watches are sharded across entries by rendezvous hash.
DAPR_ANALYTICS_WORKER_APP_IDS=analytics-worker

VMS_MTX_HOST="mediamtx"

VMS_STORAGE_BASE_PATH = /data/media_storage
VMS_LOG_PATH = /data/logs

ASPNETCORE_ENVIRONMENT=Development

# Optional: shared Keycloak login (Square's realm). Leave KEYCLOAK_URL empty to run web_vms
# standalone with no auth, exactly as before.
KEYCLOAK_URL=
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM_NAME=myrealm
KEYCLOAK_CLIENT_ID=pubclient

# Optional, dev-only: enables the unauthenticated /test/live page + api/live/whep-test/*
# endpoints for testing the MediaMTX WHEP proxy in isolation. Must stay unset in production.
VMS_LIVE_TEST_PLAYER=

# Optional: push vms_rec's cameras/properties/alarms into Square's map. Leave empty to run VmsCfg
# standalone with no Square dependency (see docs/square-integration-plan.md).
SQUARE_INTEGRATION_SINK_APP_ID=
SQUARE_INTEGRATION_DEFAULT_LAT=0
SQUARE_INTEGRATION_DEFAULT_LON=0
# Optional: origin of Square's frontend — enables CORS on web_vms for its Monitor tab.
SQUARE_FRONTEND_ORIGIN=